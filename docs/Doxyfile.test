# Doxyfile for docker-image-merge
# Tuned for Go source + doxygen-awesome-css theme

#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------
PROJECT_NAME           = "docker-image-merge"
PROJECT_NUMBER         =
PROJECT_BRIEF          = "Merge the filesystems of two Docker images with interactive conflict resolution"
OUTPUT_DIRECTORY       = output

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT                  = ../main.go \
                         ../cmd \
                         ../internal \
                         . \
                         pages
RECURSIVE              = YES
FILE_PATTERNS          = *.go *.md
EXCLUDE_PATTERNS       = */tests/* *_test.go */doxygen-awesome-css/*
IMAGE_PATH             =
USE_MDFILE_AS_MAINPAGE = mainpage.md

#---------------------------------------------------------------------------
# Extraction
#---------------------------------------------------------------------------
EXTRACT_ALL = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = NO

#---------------------------------------------------------------------------
# HTML (disabled)
#---------------------------------------------------------------------------
GENERATE_LATEX         = NO

#---------------------------------------------------------------------------
# HTML
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO

# No graphviz dependency
HAVE_DOT               = NO

# doxygen-awesome-css theme
HTML_COLORSTYLE_HUE    = 160
HTML_COLORSTYLE_SAT    = 70
HTML_COLORSTYLE_GAMMA  = 80
HTML_EXTRA_STYLESHEET  = doxygen-awesome-css/doxygen-awesome.css \
                         doxygen-awesome-css/doxygen-awesome-sidebar-only.css
HTML_EXTRA_FILES       = doxygen-awesome-css/doxygen-awesome-darkmode-toggle.js \
                         doxygen-awesome-css/doxygen-awesome-paragraph-link.js \
                         doxygen-awesome-css/doxygen-awesome-fragment-copy-button.js \
                         custom.css

# Custom header/footer
HTML_HEADER            = header.html

#---------------------------------------------------------------------------
# Miscellaneous
#---------------------------------------------------------------------------
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = NO
JAVADOC_AUTOBRIEF      = NO
OPTIMIZE_OUTPUT_JAVA   = YES
CASE_SENSE_NAMES       = YES
SHOW_NAMESPACES        = NO
SHOW_FILES             = YES
VERBATIM_HEADERS       = NO
